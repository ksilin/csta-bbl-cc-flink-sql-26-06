# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Confluent Cloud environment ID (e.g. env-abc123)
# Find with: confluent environment list
CONFLUENT_ENV_ID=env-XXXXXXX

# Flink compute pool ID (e.g. lfcp-abc123)
# Find with: confluent flink compute-pool list
COMPUTE_POOL_ID=lfcp-XXXXXXX

# Kafka cluster ID (e.g. lkc-abc123)
# Find with: confluent kafka cluster list
KAFKA_CLUSTER_ID=lkc-XXXXXXX

# Cloud provider for this environment (aws, gcp, or azure)
CLOUD_PROVIDER=aws

# Cloud region for this environment (e.g. eu-central-1, us-east-2, europe-west3)
CLOUD_REGION=eu-central-1

# Kafka cluster API key (scoped to your cluster)
# Create with: confluent api-key create --resource $KAFKA_CLUSTER_ID
KAFKA_API_KEY=XXXXXXXXXXXXXXXX
KAFKA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
